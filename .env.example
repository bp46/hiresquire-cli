# HireSquire CLI Configuration
# Get your token from https://hiresquireai.com/profile

# Required: Your API Token (sk_... or hs_...)
HIRESQUIRE_API_TOKEN=your_token_here

# Optional: API Base URL (defaults to production)
# HIRESQUIRE_BASE_URL=https://hiresquireai.com/api/v1

# Optional: Default Webhook URL for screening notifications
# HIRESQUIRE_WEBHOOK_URL=https://your-server.com/webhook
